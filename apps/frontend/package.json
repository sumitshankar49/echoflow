{
  "name": "ecoflow-frontend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check": "pnpm exec tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm run test:cov && pnpm run test:e2e",
    "prepare": "cd ../.. && ./apps/frontend/node_modules/.bin/husky .husky"
  },
  "dependencies": {

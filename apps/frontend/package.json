    "@tanstack/react-query-devtools": "^5.40.0",
    "axios": "^1.7.2",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.400.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.52.0",
    "react-player": "^3.4.0",
    "shadcn": "^4.8.0",
